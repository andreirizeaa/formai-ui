{
  "expo": {
    "name": "formai-ui",
    "slug": "formai-ui",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/formai-ios-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/formai-ios-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/formai-ios-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-mail-composer",
      "expo-video",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.666171994988-pvs957q392npltdb7u9ppq86orgvj72b"
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.useformai.formai"
    }
  }
}
